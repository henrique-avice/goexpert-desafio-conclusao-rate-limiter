# ============================================================================
# RATE LIMIT CONFIGURATION (requisições por segundo)
# ============================================================================
# Limite de requisições por IP (padrão: 10 req/s)
RATE_LIMIT_IP_REQUESTS=10

# Limite de requisições por Token API (padrão: 100 req/s)
# Token tem precedência sobre IP se ambos forem enviados
RATE_LIMIT_TOKEN_REQUESTS=100

# Tempo de bloqueio em segundos (padrão: 300 = 5 minutos)
RATE_LIMIT_BLOCK_TIME=300

# ============================================================================
# BACKEND SELECTION (redis ou memory)
# ============================================================================
# Strategy a usar: "redis" para distribuído, "memory" para em-memória
# Se Redis indisponível, fallback automático para Memory
RATE_LIMIT_BACKEND=redis

# ============================================================================
# REDIS CONFIGURATION (só necessário se RATE_LIMIT_BACKEND=redis)
# ============================================================================
# Host e porta do Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Número do banco de dados (0-15)
REDIS_DB=0

# Senha (deixar vazio se não houver autenticação)
REDIS_PASSWORD=

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Porta do servidor HTTP
SERVER_PORT=8080

# Ambiente (development, staging, production)
SERVER_ENV=development
